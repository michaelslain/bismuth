{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and app-spawned (bismuth-*) windows",
  "windows": ["main", "bismuth-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "opener:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/**" }, { "path": "/Volumes/**" }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/bismuth-core", "sidecar": true, "args": true }]
    }
  ]
}
