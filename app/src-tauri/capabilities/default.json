{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and app-spawned (oa-*) windows",
  "windows": ["main", "oa-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "opener:default",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$DOWNLOAD/*" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/bismuth-core", "sidecar": true, "args": true }]
    }
  ]
}
