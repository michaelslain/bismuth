{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bismuth",
  "version": "0.1.0",
  "identifier": "com.michael.obsidian",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run predmg:clean && bun run prebundle:relay && bun run build:bismuth-tools && bun run build && bun run build:core-sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/bismuth-core"
    ],
    "resources": [
      "resources/relay",
      "resources/bismuth-tools"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
