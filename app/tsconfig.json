{
  // Shared strict/bundler/noEmit + `types: ["bun", "node"]` come from ../tsconfig.base.json.
  // The app imports core source directly (../../core/src/*.ts), so the app program type-checks
  // core too — which uses the Bun global + node: builtins; the base's ambient `types` covers
  // both (vite/client still comes via src/vite-env.d.ts).
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
